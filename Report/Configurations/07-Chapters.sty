%%% Chapters and Sections %%%
\ifthenelse{\equal{\ChapterOption}{classic}}{
    \titleformat{\chapter}[display]%
    {\raggedright\huge}% Moved to left
    {\vspace{-2cm}\raggedright\fontsize{98}{10}\bfseries{\color{chapterdarkred}{\thechapter}}}% Moved up with -2cm
    {0pt}%
    {\minionfont\fontsize{28}{30}\selectfont}%
}{}

\ifthenelse{\equal{\ChapterOption}{fancy}}{
    \titleformat{\chapter}[display]
    {\flushleft\normalsize\huge\color{black}}% Moved to left
    {\vspace{-1cm}\flushleft\normalsize% Moved up
    {\fontsize{25}{25}\selectfont\rule[-2pt]{.1pt}{30pt}\hspace{0.5em}\raisebox{4.5pt}{\thechapter}}}%
    {5pt}% Reduced spacing
    {\addfontfeature{LetterSpace=6}\huge\scshape}%
}{}

\ifthenelse{\equal{\ChapterOption}{modern}}{
    \titleformat{\chapter}[display]
    {\normalsize\huge\color{black}}%
    {\vspace{-4cm}\minionfont\flushleft\fontsize{84}{10}\bfseries% Moved up and left
    {\color{chaptergray}\thechapter}%
    }{5pt}% Reduced spacing
    {\minionfont\addfontfeature{LetterSpace=6}\fontsize{28}{32}\MakeUppercase}%
}{}

% Sections shifted left (default)
\titleformat{\section}{\raggedright\minionfont\fontsize{15pt}{17pt}\selectfont\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\raggedright\minionfont\fontsize{13.5pt}{15.5pt}\selectfont\bfseries}{\thesubsection}{1em}{}